rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Markets: anyone can read; only Functions/server (using Admin SDK)
    // can write. The Admin SDK bypasses rules entirely.
    match /markets/{marketId} {
      allow read: if true;
      allow write: if false;
    }

    // Events: same as markets — public read, server-only write.
    match /events/{eventId} {
      allow read: if true;
      allow write: if false;
    }

    // Users: signed-in users can read/write only their own doc.
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null && request.auth.uid == uid;
      allow delete: if false;
    }

    // Leaderboard: anyone can read (it's the whole point); only server writes.
    match /leaderboard/{wallet} {
      allow read: if true;
      allow write: if false;
    }
  }
}
